generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/server_config"
}

datasource db {
    provider = "postgresql"
}

enum LogLevel {
    INFO
    WARN
    ERROR
    DEBUG
}

enum ServerType {
    STANDARD
    PAYMENT
}

enum ServerStatus {
    ONLINE
    OFFLINE
    MAINTENANCE
}

model Server {
    id         Int          @id @default(autoincrement())
    serverId   String       @unique
    host       String
    port       Int
    wsUrl      String
    status     ServerStatus
    serverType ServerType
    deviceId   String?
    createdAt  DateTime     @default(now())
    updatedAt  DateTime     @updatedAt
}

model Log {
    id        Int      @id @default(autoincrement())
    level     LogLevel @default(INFO)
    message   String
    meta      Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
