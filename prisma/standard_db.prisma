generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/standard_db"
}

datasource db {
    provider = "postgresql"
}

enum LogLevel {
    INFO
    WARN
    ERROR
    DEBUG
}

enum UserRole {
    USER
    ADMIN
}

model Account {
    id        String   @id 
    email     String   @unique
    password  String
    name      String?
    role      UserRole @default(USER)
    status    String   @default("ACTIVE")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Notification {
    id        String   @id 
    title     String
    message   String
    read      Boolean  @default(false)
    meta      Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Log {
    id        String   @id 
    level     LogLevel @default(INFO)
    message   String
    meta      Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
