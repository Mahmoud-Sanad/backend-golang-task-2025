generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/payment_db"
}

datasource db {
    provider = "postgresql"
}

enum OrderStatus {
    PENDING
    DELIVERING
    COMPLETED
    CANCELLED
}

enum LogLevel {
    INFO
    WARN
    ERROR
    DEBUG
}

enum TransactionStatus {
    REFUND
    PAID
    FAILED
}

model Product {
    id        String   @id 
    name        String
    description String?
    price       Float
    createdBy   String?
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt
    trackStock  Boolean        @default(false)
    stocks      ProductStock?  
    orderItems  OrderItem[]
}

model ProductStock {
    id        String   @id 
    productId String   @unique
    quantity  Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    alertAt   Int      @default(0)
    product   Product  @relation(fields: [productId], references: [id])
}

model Order {
    id        String   @id 
    userId       String?
    status       OrderStatus   @default(PENDING)
    total        Float
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    orderItems   OrderItem[]
    transactions Transaction[]
}

model OrderItem {
    id        String   @id 
    orderId   String
    productId String
    quantity  Int
    price     Float
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    order   Order   @relation(fields: [orderId], references: [id])
    product Product @relation(fields: [productId], references: [id])
}

model Transaction {
    id        String   @id 
    userId    String?
    status    TransactionStatus
    amount    Float
    note      String?
    orderId   String?
    order     Order?            @relation(fields: [orderId], references: [id])
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
}

model Log {
    id        String   @id 
    level     LogLevel @default(INFO)
    message   String
    meta      Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
