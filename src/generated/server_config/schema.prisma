generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/server_config"
}

datasource db {
  provider = "postgresql"
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum ServerType {
  STANDARD
  PAYMENT
}

enum ServerStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

model Server {
  id         String       @id @default(uuid())
  serverId   String       @unique
  host       String
  port       Int
  wsUrl      String
  status     ServerStatus @default(ONLINE)
  serverType ServerType   @default(STANDARD)
  deviceId   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Log {
  id        String   @id
  level     LogLevel @default(INFO)
  message   String
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
