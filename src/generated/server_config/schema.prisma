generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/server_config"
}

datasource db {
  provider = "postgresql"
}

enum ServerType {
  STANDARD
  PAYMENT
  AUTH
  OTHER
}

enum ServerStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

model Server {
  id         Int          @id @default(autoincrement())
  serverId   String       @unique
  host       String
  port       Int
  wsUrl      String
  status     ServerStatus
  serverType ServerType
  deviceId   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        Int      @id @default(autoincrement())
  level     String
  message   String
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
