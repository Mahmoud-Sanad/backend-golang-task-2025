generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/standard_db"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        Int      @id @default(autoincrement())
  level     String
  message   String
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
